# 小倩成长日记 - 监控定时任务配置
# 添加到 crontab: crontab -e

# 每 30 分钟检查一次网站健康
*/30 * * * * cd /workspace/projects/workspace/growth-diary && /usr/bin/python3 scripts/monitoring/monitor_site.py --fix >> logs/cron-monitor.log 2>&1

# 每 2 小时运行一次全面修复
0 */2 * * * cd /workspace/projects/workspace/growth-diary && /bin/bash scripts/monitoring/auto-fix.sh >> logs/cron-auto-fix.log 2>&1

# 每天 00:00 运行自动更新脚本
0 0 * * * cd /workspace/projects/workspace/growth-diary && /bin/bash auto-update.sh >> logs/auto-update.log 2>&1

# 每小时记录网站状态
0 * * * * cd /workspace/projects/workspace/growth-diary && curl -sI https://yejigang-lab.github.io/xiaoqian-growth-diary/ > logs/hourly-status-$(date +\%Y\%m\%d-\%H\%M).log 2>&1

# 每天清理一次旧日志（保留7天）
0 0 * * * find /workspace/projects/workspace/growth-diary/logs -name "*.log" -mtime +7 -delete
